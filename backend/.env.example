# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=AIVet
NODE_ENV=development
PORT=8000
RUN_LOCAL=1
FRONTEND_URL=http://localhost:3000

# ── Database (MongoDB Atlas) ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/aivet

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_EXPIRES_IN=30d
MAGIC_LINK_EXPIRES_IN=15m

# ── AI Engines ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# ── DataForSEO (Google AI Overviews) ───────────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ── Email (Gmail SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AIVet <no-reply@aivet.io>"

# ── QStash ─────────────────────────────────────────────────────────────────
QSTASH_URL=https://qstash.upstash.io/v2/publish
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Webhooks base URL ──────────────────────────────────────────────────────
WEBHOOK_BASE_URL=https://your-domain.vercel.app
