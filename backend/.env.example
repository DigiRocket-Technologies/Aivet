# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=AIVet
NODE_ENV=development            # set to "production" when deploying
PORT=8000
RUN_LOCAL=1                     # run campaign/audit jobs inline (no QStash). Keep =1 unless QStash is configured.
AUDIT_CONCURRENCY=5             # how many prompts to process in parallel during an audit (raise for speed, lower if you hit AI rate limits)

# Marketing site URL (used as a CORS fallback only).
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated origins allowed to call the API.
# In PRODUCTION set this to your dashboard frontend domain(s), e.g.
#   CORS_ORIGINS=https://app.aivet.io
# In dev, http://localhost:3000 is always allowed automatically.
CORS_ORIGINS=

# Magic-link sign-in: leave blank to use the request's Origin (recommended —
# the link points back to wherever the user signed in from). Override only if
# you must force a fixed domain, e.g. https://app.aivet.io
MAGIC_LINK_BASE_URL=
APP_URL=

# ── Database (MongoDB Atlas) ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/Aivet

# ── JWT ────────────────────────────────────────────────────────────────────
# Any one of JWT_SECRET / JWT_SECRET_KEY / AIVET_JWT_SECRET works (min 32 chars).
JWT_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=30d
MAGIC_LINK_EXPIRES_IN=15m

# ── AI Engines ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=            # optional — if blank, Gemini+Google grounding fills the "perplexity" slot

# ── DataForSEO (Google AI Overviews + domain authority) ────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (STRIPE_PRICE_AIVET_* names are what the app uses):
STRIPE_PRICE_AIVET_STARTER=
STRIPE_PRICE_AIVET_PROFESSIONAL=
STRIPE_PRICE_AIVET_ENTERPRISE=

# ── Email ──────────────────────────────────────────────────────────────────
# PREFERRED (instant + reliable on serverless): Resend HTTP API.
# Sign up free at resend.com, create an API key, set it here. If unset, the app
# falls back to Gmail SMTP below (slow/flaky on Vercel).
RESEND_API_KEY=
# From address. "onboarding@resend.dev" works WITHOUT domain verification but
# only delivers to YOUR Resend signup email (good for testing). To email any
# user, verify a domain in Resend and use e.g. "AIVet <no-reply@yourdomain.com>".
RESEND_FROM="AIVet <onboarding@resend.dev>"

# Gmail SMTP fallback (used only when RESEND_API_KEY is empty):
GMAIL_ACCOUNT=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM="AIVet <no-reply@aivet.io>"

# ── QStash (optional async job queue) ──────────────────────────────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Webhooks base URL ──────────────────────────────────────────────────────
WEBHOOK_BASE_URL=https://your-domain.vercel.app
